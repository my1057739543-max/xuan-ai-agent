# Copy values into local .env for docker compose or IDE environment variables.
# Do NOT commit real secrets.

# PostgreSQL
POSTGRES_DB=xuan_open_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring AI model keys
SPRING_AI_DEEPSEEK_API_KEY=your_deepseek_api_key
SPRING_AI_DASHSCOPE_API_KEY=your_dashscope_api_key

# Optional tool key
XUAN_TOOLS_WEB_SEARCH_API_KEY=your_tavily_api_key

# Optional MCP/map key (if MCP enabled)
AMAP_MAPS_API_KEY=your_amap_maps_api_key
